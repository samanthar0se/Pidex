{
  "name": "pidex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/check-development-prerequisites.mjs",
    "dev": "node --env-file-if-exists=.env --import tsx packages/host/src/development.ts",
    "dev:ca:setup": "tsx packages/host/src/development-ca-setup.ts",
    "dev:ca:reset": "tsx packages/host/src/development-ca-reset.ts",
    "dev:task:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/development-host-task.ps1 install",
    "dev:task:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/development-host-task.ps1 restart",
    "dev:task:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/development-host-task.ps1 status",
    "dev:task:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/development-host-task.ps1 stop",
    "dev:task:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/development-host-task.ps1 uninstall",
    "sandcastle": "tsx .sandcastle/main.mts",
    "status": "tsx packages/cli/src/main.ts status",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "build:client": "vite build apps/client --config apps/client/vite.config.ts",
    "secret-scan": "node scripts/secret-scan.mjs",
    "security": "npm run secret-scan && npm audit --omit=dev --audit-level=high && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "ws": "^8.21.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
